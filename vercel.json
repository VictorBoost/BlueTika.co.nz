{
  "version": 2,
  "public": true,
  "alias": ["bluetika.co.nz"],
  "framework": "nextjs",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        { "type": "host", "value": "www.bluetika.co.nz" }
      ],
      "destination": "https://bluetika.co.nz/$1",
      "permanent": true
    },
    {
      "source": "/old-path",
      "destination": "/new-path",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "crons": [
    {
      "path": "/api/escrow/auto-release-pipeline",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/escrow/friday-payout",
      "schedule": "0 20 * * 4"
    }
  ]
}